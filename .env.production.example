# net4.xyz Production Environment Configuration
# Copy this file to .env and fill in the values

# ===================
# Database
# ===================
MONGO_USER=net4xyz_prod
MONGO_PASSWORD=change_me_in_production
DATABASE_URL=mongodb://net4xyz_prod:password@mongodb-primary:27017/net4xyz?replicaSet=rs0

# ===================
# Authentication
# ===================
JWT_SECRET=change_me_to_random_256_bit_secret
JWT_EXPIRES_IN=7d

# ===================
# API Keys
# ===================
# Blockchain
BASE_RPC_URL=https://mainnet.base.org
PRIVATE_KEY=your_deployer_private_key

# AI Services
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
VLLM_API_KEY=...

# ===================
# External Services
# ===================
# Payment
TRANSADK_API_KEY=...
SIMPLEX_API_KEY=...

# Email (for alerts)
SMTP_USERNAME=alerts@net4.xyz
SMTP_PASSWORD=your_smtp_password

# Slack (for critical alerts)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ===================
# Monitoring
# ===================
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_me

# ===================
# Domain
# ===================
DOMAIN=net4.xyz
API_DOMAIN=api.net4.xyz

# ===================
# Feature Flags
# ===================
ENABLE_SIGNUP=true
ENABLE_PAYMENT=true
ENABLE_AI_ENGINE=true