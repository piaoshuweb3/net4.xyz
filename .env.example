# net4.xyz 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ===================
# 通用配置
# ===================
NODE_ENV=development
DEBUG=true

# ===================
# 管理权限配置
# ===================
# 终极管理员地址 — 拥有最高后台权限
NEXT_PUBLIC_ADMIN_ADDRESS=0x_Your_Admin_Wallet_Address_Here

# ===================
# 数据库配置
# ===================
DATABASE_URL=mongodb://net4xyz:net4xyz123@localhost:27017/net4xyz
MONGO_USER=net4xyz
MONGO_PASSWORD=CHANGE_ME_use_strong_random_password

# ===================
# JWT 配置
# ===================
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ===================
# 区块链配置
# ===================
# 部署者私钥（不要提交到版本控制！）
DEPLOYER_PRIVATE_KEY=0x...

# Base Sepolia RPC
SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Base 主网 RPC
BASE_RPC_URL=https://mainnet.base.org

# AFC 主网 RPC（待部署）
AFC_RPC_URL=

# Etherscan API Key（用于验证合约）
ETHERSCAN_API_KEY=your-etherscan-api-key

# ===================
# 合约地址（测试网）
# ===================
NEXT_PUBLIC_AFC_TOKEN_SEPOLIA=
NEXT_PUBLIC_SPARK_NFT_SEPOLIA=
NEXT_PUBLIC_PUE_CONSENSUS_SEPOLIA=
NEXT_PUBLIC_NODE_REGISTRY_SEPOLIA=
NEXT_PUBLIC_WEB4_DNS_SEPOLIA=
NEXT_PUBLIC_MIRROME_SOCIAL_SEPOLIA=

# ===================
# 合约地址（主网）
# ===================
NEXT_PUBLIC_AFC_TOKEN_BASE=
NEXT_PUBLIC_SPARK_NFT_BASE=
NEXT_PUBLIC_PUE_CONSENSUS_BASE=
NEXT_PUBLIC_NODE_REGISTRY_BASE=
NEXT_PUBLIC_WEB4_DNS_BASE=
NEXT_PUBLIC_MIRROME_SOCIAL_BASE=

# ===================
# 存储配置
# ===================
IPFS_PINNING_SERVICE=
ARWEAVE_WALLET=
NEXT_PUBLIC_IPFS_GATEWAY=https://ipfs.io/ipfs/

# ===================
# AI 服务配置
# ===================
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ===================
# 支付网关配置
# ===================
TRANSAK_API_KEY=
SIMPLEX_API_KEY=

# ===================
# 第三方服务
# ===================
# Vercel（部署用）
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# Cloudflare（可选）
CLOUDFLARE_API_KEY=
CLOUDFLARE_EMAIL=

# ===================
# 监控配置
# ===================
SENTRY_DSN=
DATADOG_API_KEY=

# ===================
# Gas 报告
# ===================
REPORT_GAS=true
COINMARKETCAP_API_KEY=