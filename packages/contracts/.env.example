# net4.xyz Smart Contract Deployment Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# REQUIRED - Deployment
# ===========================================

# Deployer wallet private key (WITHOUT 0x prefix for Hardhat)
# WARNING: Never commit this file to version control!
DEPLOYER_PRIVATE_KEY=your-private-key-without-0x-prefix

# ===========================================
# REQUIRED - RPC URLs
# ===========================================

# Ethereum Sepolia Testnet RPC
SEPOLIA_RPC_URL=https://rpc.sepolia.org

# Base Sepolia Testnet RPC
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Base Mainnet RPC
BASE_RPC_URL=https://mainnet.base.org

# ===========================================
# OPTIONAL - API Keys (for contract verification)
# ===========================================

# Etherscan/Basescan API Key
# Get free key at: https://basescan.org/apis
ETHERSCAN_API_KEY=your-basescan-api-key

# CoinMarketCap API (for gas reporting)
COINMARKETCAP_API_KEY=your-coinmarketcap-api-key

# ===========================================
# OPTIONAL - Gas Settings
# ===========================================

# Enable gas reporting (true/false)
REPORT_GAS=false
