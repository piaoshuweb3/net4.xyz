{
  "name": "@net4xyz/frontend",
  "version": "1.0.0",
  "description": "net4.xyz 前端应用 - React + Next.js + Three.js + Wagmi",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev --turbo",
    "dev:fast": "next dev --turbo --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:a11y": "playwright test --project=accessibility",
    "test:perf": "playwright test --project=performance",
    "test:all": "vitest --run && playwright test",
    "test:lighthouse": "ts-node scripts/lighthouse-audit.ts",
    "clean": "rm -rf .next out"
  },
  "dependencies": {
    "@net4xyz/shared": "workspace:*",
    "@rainbow-me/rainbowkit": "^2.0.0",
    "@tanstack/react-query": "^5.17.0",
    "@wagmi/core": "^2.6.0",
    "cross-fetch": "^4.0.0",
    "debug": "^4.3.4",
    "eventemitter2": "^6.4.9",
    "framer-motion": "^10.18.0",
    "i18next": "^26.2.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.312.0",
    "next": "14.1.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-i18next": "^17.0.8",
    "socket.io-client": "^4.5.1",
    "three": "^0.160.0",
    "uuid": "^8.3.2",
    "viem": "^2.7.0",
    "wagmi": "^2.5.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.8.0",
    "@playwright/test": "^1.41.0",
    "@testing-library/jest-dom": "^6.1.0",
    "@testing-library/react": "^14.1.0",
    "@types/node": "^20.19.39",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.2.0",
    "@types/three": "^0.160.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.56.0",
    "eslint-config-next": "14.1.0",
    "jsdom": "^23.0.0",
    "lighthouse": "^11.4.0",
    "playwright": "^1.41.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}