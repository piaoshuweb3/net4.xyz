# net4.xyz Backend Environment Variables

# ==================== 数据库 ====================
# MongoDB 集群连接字符串 (读写分离)
DATABASE_URL="mongodb://net4xyz:net4xyz123@localhost:27017,localhost:27018,localhost:27019/net4xyz?replicaSet=rs0&readPreference=secondaryPreferred"
DATABASE_READ_URL="mongodb://net4xyz:net4xyz123@localhost:27018,localhost:27019/net4xyz?replicaSet=rs0&readPreference=secondaryPreferred"
DATABASE_WRITE_URL="mongodb://net4xyz:net4xyz123@localhost:27017/net4xyz?replicaSet=rs0"

# PostgreSQL (保留用于某些需要事务支持的场景)
POSTGRES_URL="postgresql://user:password@localhost:5432/net4xyz"

# MongoDB 集群配置
MONGO_REPLICA_SET="rs0"
MONGO_AUTH_SOURCE="admin"

# ==================== 应用配置 ====================
NODE_ENV="development"
PORT=3000
FRONTEND_URL="http://localhost:3001"
BACKEND_URL="http://localhost:3000"
GRAPHQL_PATH="/graphql"
CORS_ORIGIN="http://localhost:3001"

# ==================== JWT 配置 ====================
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# ==================== OAuth 配置 ====================
# Twitter
TWITTER_CLIENT_ID=""
TWITTER_CLIENT_SECRET=""
TWITTER_CALLBACK_URL="http://localhost:3000/auth/twitter/callback"

# Google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3000/auth/google/callback"

# ==================== 支付网关 ====================
# Transak
TRANSAK_API_KEY=""
TRANSAK_API_URL="https://api.transak.com"

# Simplex
SIMPLEX_API_KEY=""
SIMPLEX_API_URL="https://api.simplex.com"

# USDT 收款地址
USDT_RECEIVE_ADDRESS=""
USDT_CONTRACT_ADDRESS=""

# ==================== KYC 验证 ====================
# SumSub KYC 服务
SUMSUB_API_KEY=""
SUMSUB_API_URL="https://api.sumsub.com"
SUMSUB_APP_ID=""

# ==================== 区块链 ====================
BLOCKCHAIN_RPC_URL="https://sepolia.base.org"
PRIVATE_KEY=""

# 合约地址
AFC_TOKEN_ADDRESS=""
SPARK_NFT_ADDRESS=""
PUE_CONSENSUS_ADDRESS=""

# ==================== 存储 ====================
# AWS S3
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_S3_BUCKET="net4xyz-media"

# IPFS
IPFS_URL="http://localhost:5001"
IPFS_GATEWAY="http://localhost:8080"
IPFS_CLUSTER_PEERS="/ip4/172.18.0.10/tcp/4001/p2p/QmNode2,/ip4/172.18.0.11/tcp/4001/p2p/QmNode3"

# Pinata (备选)
PINATA_API_KEY=""
PINATA_SECRET_KEY=""

# Arweave
ARWEAVE_HOST="arweave.net"
ARWEAVE_PORT=443
ARWEAVE_HTTPS=true
ARWEAVE_WALLET_JWK='{"kty":"RSA","n":"...","e":"AQAB","d":"...","p":"...","q":"...","dp":"...","dq":"...","qi":"..."}'

# ==================== 数据可用性层 (DA) ====================
# DA Provider: celestia or eigenda
DA_PROVIDER="celestia"

# Celestia
CELESTIA_RPC_URL="http://localhost:26657"
CELESTIA_TOKEN=""

# EigenDA
EIGENDA_URL="https://eigenda.xyz"
EIGENDA_OPERATOR_KEY=""

# ==================== 邮件 ====================
SENDGRID_API_KEY=""
FROM_EMAIL="noreply@net4.xyz"
FROM_NAME="net4.xyz"

# ==================== gRPC 配置 ====================
GRPC_HOST="localhost"
GRPC_PORT=50051

# gRPC 服务端口
USER_SERVICE_PORT=50051
BLOCKCHAIN_SERVICE_PORT=50052
PAYMENT_SERVICE_PORT=50053
CONTENT_SERVICE_PORT=50054
NODE_SERVICE_PORT=50055

# ==================== 服务发现 ====================
SERVICE_DISCOVERY_ENABLED=true
SERVICE_HEARTBEAT_INTERVAL=10000

# ==================== 监控 ====================
SENTRY_DSN=""

# ==================== API 网关配置 ====================
# Rate Limiting
RATE_LIMIT_TTL=60000
RATE_LIMIT_DEFAULT=100
RATE_LIMIT_LOGIN=5
RATE_LIMIT_REGISTER=3

# Request Logging
REQUEST_LOG_ENABLED=true
REQUEST_LOG_MAX_ENTRIES=1000

# API Gateway
API_GATEWAY_ENABLED=true
API_GATEWAY_METRICS_INTERVAL=300000
# ==================== 跨链桥接 (Bridge) ====================
# Base Chain Configuration
BASE_RPC_URL="https://sepolia.base.org"
BASE_CHAIN_ID=84532
BASE_PRIVATE_KEY=""
BASE_BRIDGE_ADDRESS=""

# AFC Chain Configuration
AFC_RPC_URL="http://localhost:8545"
AFC_CHAIN_ID=12345
AFC_PRIVATE_KEY=""
AFC_BRIDGE_ADDRESS=""

# Bridge Configuration
BRIDGE_MESSAGE_EXPIRY=86400  # 24 hours in seconds
BRIDGE_REQUIRED_CONFIRMATIONS=12
BRIDGE_FALLBACK_ENABLED=true