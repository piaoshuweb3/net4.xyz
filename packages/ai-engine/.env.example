# net4.xyz AI Engine Environment Variables
# 轨道 A：云端 API 服务

# ==================== 服务配置 ====================
HOST="0.0.0.0"
PORT=8000
LOG_LEVEL="info"
NODE_ENV="development"

# ==================== CORS ====================
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"

# ==================== 开发模式 ====================
# 允许无 API 密钥访问（仅开发环境）
ALLOW_NO_KEY="false"

# ==================== OpenAI API ====================
OPENAI_API_KEY="sk-your-openai-api-key-here"
OPENAI_MODEL="gpt-4o"

# ==================== Anthropic API ====================
ANTHROPIC_API_KEY="sk-ant-your-anthropic-api-key-here"
ANTHROPIC_MODEL="claude-3-5-sonnet-20241022"

# ==================== AI 服务配置 ====================
# 默认温度
AI_TEMPERATURE="0.7"
# 最大 token 数
AI_MAX_TOKENS="4096"
# 超时时间（秒）
AI_TIMEOUT="60"
# 最大重试次数
AI_MAX_RETRIES="3"

# ==================== 负载均衡 ====================
# 策略: round_robin, least_loaded, weighted, hash
LOAD_BALANCING_STRATEGY="weighted"
# 启用回退
ENABLE_FALLBACK="true"

# ==================== API 密钥管理 ====================
# API 密钥前缀
API_KEY_PREFIX="nk4_"
# 密钥过期天数（0 = 永不过期）
KEY_EXPIRY_DAYS="365"

# ==================== 速率限制 ====================
# 默认速率限制（每分钟）
DEFAULT_RATE_LIMIT="60"
# 默认月度配额
DEFAULT_MONTHLY_QUOTA="10000"

# ==================== 监控 ====================
# Sentry DSN
SENTRY_DSN=""
# Prometheus 指标
ENABLE_METRICS="true"
METRICS_PORT="9090"

# ==================== 轨道 B：本地模型部署 ====================

# ==================== Ollama 配置 ====================
# Ollama 服务地址
OLLAMA_BASE_URL="http://localhost:11434"
# Ollama 请求超时（秒）
OLLAMA_TIMEOUT="300"

# ==================== vLLM 配置 ====================
# vLLM 服务地址
VLLM_BASE_URL="http://localhost:8000"
# vLLM 请求超时（秒）
VLLM_TIMEOUT="300"

# ==================== 本地模型配置 ====================
# 默认本地模型
DEFAULT_LOCAL_MODEL="llama3:70b"

# ==================== 模型硬件要求 ====================
# 核心节点模型（需要 H100/A100）
# - llama3:405b
# - llama-3-405b-instruct (vLLM)

# 子节点模型（需要 RTX 4090/3090）
# - llama3:70b
# - mixtral:8x22b
# - llama-3-70b-instruct (vLLM)
# - mixtral-8x22b-instruct (vLLM)

# 轻量模型（需要 RTX 3080+）
# - llama3:8b
# - mixtral:8x7b
# ==================== AI 内容安全过滤 ====================

# Azure 内容安全 API（可选）
AZURE_CONTENT_SAFETY_ENDPOINT="https://your-resource.cognitiveservices.azure.com"
AZURE_CONTENT_SAFETY_KEY="your-azure-key"

# 自定义内容安全 API（可选）
CONTENT_SAFETY_API_ENDPOINT=""
CONTENT_SAFETY_API_KEY=""

# 本地过滤配置
ENABLE_LOCAL_FILTER="true"
# 逗号分隔的禁用关键词
BLOCKED_KEYWORDS="spam,scam,illegal,prohibited,phishing,malware"

# 阈值配置（0-1）
HATE_SPEECH_THRESHOLD="0.7"
VIOLENCE_THRESHOLD="0.7"
SEXUAL_THRESHOLD="0.7"
SELF_HARM_THRESHOLD="0.5"
HARASSMENT_THRESHOLD="0.7"
EMOTIONAL_MANIPULATION_THRESHOLD="0.6"

# 情感安全配置
ENABLE_EMOTIONAL_SAFETY="true"
MAX_EMOTIONAL_INTENSITY="8.5"

# 行为配置
AUTO_BLOCK_HIGH_RISK="true"
AUTO_FILTER_MEDIUM_RISK="true"
LOG_VIOLATIONS="true"

# ==================== 数据库配置 ====================

# MongoDB 配置
MONGODB_URI="mongodb://localhost:27017"
MONGODB_DB_NAME="net4_ai_engine"
MONGODB_USERNAME=""
MONGODB_PASSWORD=""
# MongoDB 连接池大小
MONGODB_MAX_POOL_SIZE="100"
MONGODB_MIN_POOL_SIZE="10"

# Redis 配置
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""
REDIS_DB="0"
# Redis 连接池大小
REDIS_MAX_CONNECTIONS="50"

# ==================== RAG 配置 ====================

# 向量数据库类型: chroma, faiss
VECTOR_STORE_TYPE="chroma"
# Chroma 持久化目录
CHROMA_PERSIST_DIR="./data/chroma_db"
# FAISS 索引目录
FAISS_INDEX_DIR="./data/faiss_index"

# 嵌入模型配置
EMBEDDING_MODEL="openai"
# 本地嵌入模型路径（可选）
LOCAL_EMBEDDING_MODEL=""
# 嵌入维度
EMBEDDING_DIMENSION="1536"

# 文档处理配置
CHUNK_SIZE="1000"
CHUNK_OVERLAP="200"
# 支持的文件类型
SUPPORTED_FILE_TYPES="txt,pdf,md,json,csv"
# 最大文件大小（MB）
MAX_FILE_SIZE="50"

# RAG 检索配置
RAG_TOP_K="4"
RAG_ENABLE_COMPRESSION="true"
# 最小相似度阈值
RAG_MIN_SIMILARITY="0.5"

# ==================== 知识库配置 ====================

# 知识库数据目录
KNOWLEDGE_BASE_DIR="./data/knowledge_base"
# 知识库版本
KNOWLEDGE_BASE_VERSION="1.0.0"
# 知识库更新检查间隔（小时）
KNOWLEDGE_UPDATE_INTERVAL="24"

# ==================== 日志配置 ====================

# 日志格式
LOG_FORMAT="json"
# 日志文件路径
LOG_FILE="./logs/ai_engine.log"
# 日志文件大小（MB）
LOG_FILE_MAX_SIZE="100"
# 保留的日志文件数量
LOG_BACKUP_COUNT="10"
# 控制台日志
LOG_TO_CONSOLE="true"
# 文件日志
LOG_TO_FILE="true"

# ==================== 文件存储配置 ====================

# 上传文件临时目录
UPLOAD_TEMP_DIR="./data/uploads"
# 模型缓存目录
MODEL_CACHE_DIR="./data/model_cache"
# 训练数据目录
TRAINING_DATA_DIR="./data/training_data"

# ==================== 任务编排配置 ====================

# 最大并发任务数
MAX_CONCURRENT_TASKS="10"
# 任务超时时间（秒）
TASK_TIMEOUT="300"
# 任务重试次数
TASK_MAX_RETRIES="3"
# 任务队列大小
TASK_QUEUE_SIZE="100"

# ==================== 微调训练配置 ====================

# 训练输出目录
TRAINING_OUTPUT_DIR="./data/training_output"
# 训练检查点保存间隔（步数）
CHECKPOINT_SAVE_INTERVAL="100"
# 最大训练 epochs
MAX_TRAINING_EPOCHS="10"

# ==================== ZK-ML 配置（可选） ====================

# ZK 证明生成配置
ZK_CIRCUIT_VERSION="v1"
ZK_PROOF_TIMEOUT="600"
# snarkjs 路径（可选）
SNARKJS_PATH=""