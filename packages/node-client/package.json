{
  "name": "@net4xyz/node-client",
  "version": "1.0.0",
  "description": "net4.xyz 节点客户端 - 桌面端软件，支持 PoUE 共识机制",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "electron .",
    "build": "tsc && electron-builder",
    "build:win": "tsc && electron-builder --win",
    "build:mac": "tsc && electron-builder --mac",
    "build:linux": "tsc && electron-builder --linux",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest",
    "clean": "rm -rf dist release"
  },
  "dependencies": {
    "@net4xyz/shared": "workspace:*",
    "electron-log": "^5.0.0",
    "electron-updater": "^6.1.0",
    "systeminformation": "^5.21.0",
    "viem": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "build": {
    "appId": "xyz.net4.node-client",
    "productName": "net4xyz Node Client",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}